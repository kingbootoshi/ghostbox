#!/usr/bin/env bash
set -euo pipefail

# ghost-memory: Persistent curated memory for ghost agents.
# Two markdown files with free-form entries separated by section signs.
# Follows the Hermes Agent memory pattern.
#
# Files:
#   /vault/MEMORY.md  - Agent's personal notes (env facts, conventions, quirks, file index)
#   /vault/USER.md    - What the agent knows about the user (preferences, style, role)
#
# Entry delimiter: a line containing only "§"
# Character limits: MEMORY 4000 chars, USER 2000 chars
#
# Usage:
#   ghost-memory add <target> "content"                  Append a new entry
#   ghost-memory replace <target> "old_text" "new"       Find entry by substring, replace it
#   ghost-memory remove <target> "old_text"              Find entry by substring, delete it
#   ghost-memory show [target]                           Show entries with usage stats
#
# Targets: memory, user

VAULT="/vault"
MEMORY_FILE="$VAULT/MEMORY.md"
USER_FILE="$VAULT/USER.md"
DELIMITER=$'\n§\n'
MEMORY_LIMIT=4000
USER_LIMIT=2000

file_for_target() {
  case "$1" in
    memory) echo "$MEMORY_FILE" ;;
    user)   echo "$USER_FILE" ;;
    *)      echo "Error: target must be 'memory' or 'user'" >&2; exit 1 ;;
  esac
}

limit_for_target() {
  case "$1" in
    memory) echo "$MEMORY_LIMIT" ;;
    user)   echo "$USER_LIMIT" ;;
  esac
}

label_for_target() {
  case "$1" in
    memory) echo "MEMORY (your personal notes)" ;;
    user)   echo "USER (who the user is)" ;;
  esac
}

ensure_file() {
  local file="$1"
  if [ ! -f "$file" ]; then
    touch "$file"
  fi
}

# Read file into entries array (newline-separated, § as delimiter)
# Output: one entry per line (entries themselves have newlines replaced with \x00 temporarily)
read_entries() {
  local file="$1"
  ensure_file "$file"
  local content
  content=$(cat "$file")
  if [ -z "$content" ]; then
    return
  fi
  # Split by §-on-its-own-line, trim each entry
  echo "$content" | awk '
    BEGIN { entry="" }
    /^§$/ {
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", entry)
      if (entry != "") print entry
      entry=""
      next
    }
    {
      if (entry != "") entry = entry "\n" $0
      else entry = $0
    }
    END {
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", entry)
      if (entry != "") print entry
    }
  '
}

# Write entries back to file with § delimiters
write_entries() {
  local file="$1"
  shift
  local tmp
  tmp=$(mktemp "$VAULT/.mem_XXXXXX")

  if [ $# -eq 0 ]; then
    mv "$tmp" "$file"
    return
  fi

  local first=1
  for entry in "$@"; do
    if [ "$first" -eq 1 ]; then
      first=0
    else
      printf '\n§\n' >> "$tmp"
    fi
    printf '%s' "$entry" >> "$tmp"
  done

  mv "$tmp" "$file"
}

char_count() {
  local file="$1"
  ensure_file "$file"
  wc -c < "$file" | tr -d ' '
}

usage_display() {
  local target="$1"
  local file
  file=$(file_for_target "$target")
  local limit
  limit=$(limit_for_target "$target")
  local current
  current=$(char_count "$file")
  local pct=$(( current * 100 / limit ))
  echo "${pct}% - ${current}/${limit} chars"
}

cmd_add() {
  local target="${1:?Usage: ghost-memory add <target> \"content\"}"
  local content="${2:?Usage: ghost-memory add <target> \"content\"}"
  local file
  file=$(file_for_target "$target")
  local limit
  limit=$(limit_for_target "$target")

  ensure_file "$file"

  # Check for duplicate
  local existing
  existing=$(cat "$file")
  if echo "$existing" | grep -qF "$content"; then
    echo "Entry already exists (no duplicate added)."
    echo "Usage: $(usage_display "$target")"
    exit 0
  fi

  # Check size limit
  local current
  current=$(char_count "$file")
  local new_size=$(( current + ${#content} + ${#DELIMITER} ))
  if [ "$new_size" -gt "$limit" ]; then
    echo "Error: memory at ${current}/${limit} chars. Adding ${#content} chars would exceed limit." >&2
    echo "Replace or remove existing entries first." >&2
    exit 1
  fi

  # Append
  if [ -s "$file" ]; then
    printf '\n§\n%s' "$content" >> "$file"
  else
    printf '%s' "$content" > "$file"
  fi

  echo "Entry added to $target."
  echo "Usage: $(usage_display "$target")"
}

cmd_replace() {
  local target="${1:?Usage: ghost-memory replace <target> \"old_text\" \"new_content\"}"
  local old_text="${2:?Usage: ghost-memory replace <target> \"old_text\" \"new_content\"}"
  local new_content="${3:?Usage: ghost-memory replace <target> \"old_text\" \"new_content\"}"
  local file
  file=$(file_for_target "$target")
  local limit
  limit=$(limit_for_target "$target")

  ensure_file "$file"

  # Read entries into an array
  local -a entries=()
  local -a matches=()
  local idx=0

  while IFS= read -r entry; do
    entries+=("$entry")
    if echo "$entry" | grep -qF "$old_text"; then
      matches+=("$idx")
    fi
    idx=$(( idx + 1 ))
  done < <(read_entries "$file")

  if [ ${#matches[@]} -eq 0 ]; then
    echo "Error: no entry matched '$old_text'" >&2
    exit 1
  fi

  if [ ${#matches[@]} -gt 1 ]; then
    echo "Error: multiple entries matched '$old_text'. Be more specific." >&2
    for m in "${matches[@]}"; do
      echo "  - ${entries[$m]:0:80}..." >&2
    done
    exit 1
  fi

  # Replace the matched entry
  entries[${matches[0]}]="$new_content"

  # Check size limit
  write_entries "$file" "${entries[@]}"
  local new_size
  new_size=$(char_count "$file")
  if [ "$new_size" -gt "$limit" ]; then
    echo "Warning: memory now at ${new_size}/${limit} chars (over limit)." >&2
  fi

  echo "Entry replaced in $target."
  echo "Usage: $(usage_display "$target")"
}

cmd_remove() {
  local target="${1:?Usage: ghost-memory remove <target> \"old_text\"}"
  local old_text="${2:?Usage: ghost-memory remove <target> \"old_text\"}"
  local file
  file=$(file_for_target "$target")

  ensure_file "$file"

  local -a entries=()
  local -a keep=()
  local -a matches=()
  local idx=0

  while IFS= read -r entry; do
    entries+=("$entry")
    if echo "$entry" | grep -qF "$old_text"; then
      matches+=("$idx")
    fi
    idx=$(( idx + 1 ))
  done < <(read_entries "$file")

  if [ ${#matches[@]} -eq 0 ]; then
    echo "Error: no entry matched '$old_text'" >&2
    exit 1
  fi

  if [ ${#matches[@]} -gt 1 ]; then
    echo "Error: multiple entries matched '$old_text'. Be more specific." >&2
    for m in "${matches[@]}"; do
      echo "  - ${entries[$m]:0:80}..." >&2
    done
    exit 1
  fi

  # Rebuild without the matched entry
  local remove_idx="${matches[0]}"
  for (( i=0; i<${#entries[@]}; i++ )); do
    if [ "$i" -ne "$remove_idx" ]; then
      keep+=("${entries[$i]}")
    fi
  done

  write_entries "$file" "${keep[@]}"

  echo "Entry removed from $target."
  echo "Usage: $(usage_display "$target")"
}

cmd_show() {
  local target="${1:-}"

  if [ -n "$target" ]; then
    local file
    file=$(file_for_target "$target")
    local label
    label=$(label_for_target "$target")
    ensure_file "$file"
    echo "== $label [$(usage_display "$target")] =="
    cat "$file"
    echo ""
  else
    for t in memory user; do
      local f
      f=$(file_for_target "$t")
      local l
      l=$(label_for_target "$t")
      ensure_file "$f"
      echo "== $l [$(usage_display "$t")] =="
      cat "$f"
      echo ""
    done
  fi
}

cmd_help() {
  echo "ghost-memory: Persistent curated memory"
  echo ""
  echo "Files:"
  echo "  MEMORY.md  - Your notes (env, conventions, quirks, file references)"
  echo "  USER.md    - Who the user is (preferences, role, style)"
  echo ""
  echo "Commands:"
  echo "  add <target> \"content\"                  Add an entry"
  echo "  replace <target> \"old_text\" \"new\"       Replace entry matching old_text"
  echo "  remove <target> \"old_text\"              Remove entry matching old_text"
  echo "  show [target]                           Show entries with usage"
  echo ""
  echo "Targets: memory, user"
  echo "Limits: memory ${MEMORY_LIMIT} chars, user ${USER_LIMIT} chars"
}

action="${1:-help}"
shift || true

case "$action" in
  add)     cmd_add "$@" ;;
  replace) cmd_replace "$@" ;;
  remove)  cmd_remove "$@" ;;
  show)    cmd_show "$@" ;;
  help|--help|-h) cmd_help ;;
  *)
    echo "Unknown command: $action" >&2
    cmd_help >&2
    exit 1
    ;;
esac
