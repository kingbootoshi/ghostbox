#!/usr/bin/env bash
set -euo pipefail

# ghost-nudge: Agent self-activation via the nudge system.
# Triggers nudge events on the local ghost-server.
#
# Usage:
#   ghost-nudge memory              Trigger memory review nudge
#   ghost-nudge timer "reason"      Trigger a timer event
#   ghost-nudge self "reason"       Trigger a self-scheduled event
#   ghost-nudge status              Show nudge system status

PORT="${GHOST_PORT:-3000}"
BASE="http://localhost:$PORT"

# Auth: read API key from env (set by entrypoint) or state file
AUTH_HEADER=""
if [ -n "${GHOST_API_KEY:-}" ]; then
  AUTH_HEADER="Authorization: Bearer $GHOST_API_KEY"
fi

nudge_post() {
  local event="$1"
  local reason="$2"
  local payload
  payload=$(printf '{"event":"%s","reason":"%s"}' "$event" "$reason")
  if [ -n "$AUTH_HEADER" ]; then
    curl -sS -X POST "$BASE/nudge" \
      -H "Content-Type: application/json" \
      -H "$AUTH_HEADER" \
      -d "$payload" 2>/dev/null
  else
    curl -sS -X POST "$BASE/nudge" \
      -H "Content-Type: application/json" \
      -d "$payload" 2>/dev/null
  fi
}

case "${1:-help}" in
  memory)
    nudge_post "self" "agent-memory-review"
    ;;
  timer)
    nudge_post "timer" "${2:-agent-timer}"
    ;;
  self)
    nudge_post "self" "${2:-agent-self-nudge}"
    ;;
  status)
    if [ -n "$AUTH_HEADER" ]; then
      curl -sS "$BASE/nudge/status" -H "$AUTH_HEADER" 2>/dev/null
    else
      curl -sS "$BASE/nudge/status" 2>/dev/null
    fi
    ;;
  help|--help|-h)
    cat <<'USAGE'
ghost-nudge - Agent self-activation via the nudge system

Commands:
  memory            Trigger memory review (observer extracts facts now)
  timer "reason"    Fire a timer nudge with given reason
  self "reason"     Fire a self-scheduled nudge
  status            Show nudge system status (handlers, counters)

Examples:
  ghost-nudge memory
  ghost-nudge self "check-on-deploy-status"
  ghost-nudge timer "daily-review"
  ghost-nudge status
USAGE
    ;;
  *)
    echo "Unknown command: $1" >&2
    echo "Run 'ghost-nudge help' for usage" >&2
    exit 1
    ;;
esac
