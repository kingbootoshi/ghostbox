{
  "name": "ghostbox",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "ghostbox": "./dist/cli.js"
  },
  "scripts": {
    "build:ghost": "bun build src/ghost-server.ts --target=node --outfile=docker/ghost-server.js --external @mariozechner/pi-coding-agent",
    "build:cli": "bun build src/cli.ts --outdir=dist --target=bun",
    "build:image": "docker build -t ghostbox-agent docker/",
    "build": "bun run build:ghost && bun run build:image && bun run build:cli",
    "dev": "bun run src/cli.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@grammyjs/auto-retry": "^2.0.2",
    "chalk": "^5.4.1",
    "dockerode": "^4.0.5",
    "grammy": "^1.39.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/dockerode": "^4.0.1",
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
